# ═══════════════════════════════════════════════
# K_M_Cart Server Environment Variables
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For production deployment (Render/Vercel):
#   Set these in the hosting dashboard → Environment Variables
# ═══════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MONGODB ─────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/DATABASE
# ⚠️ Password must NOT contain special characters like @, #, %, etc.
# ⚠️ For cloud hosting: Set Atlas Network Access → IP Whitelist → 0.0.0.0/0
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/gkcart?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────
# Use a long, random string (min 64 chars recommended)
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# ── CLIENT URL (for CORS) ──────────────────────
# Development: http://localhost:5173
# Production: your Vercel frontend URL (NO trailing slash!)
# Multiple origins: comma-separated
# Example: CLIENT_URL=https://km-cart.vercel.app,https://www.km-cart.com
CLIENT_URL=http://localhost:5173

# ── RAZORPAY ────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ keys for testing, rzp_live_ for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
